{
  "$schema": "https://raw.githubusercontent.com/dotnet/docfx/main/schemas/docfx.schema.json",
  "metadata": [
    {
      "src": [
        {
          "src": "../",
          "files": [
            "Boist/*.csproj",
            "Boist.Audio/*.csproj",
            "Boist.Graphics/*.csproj",
            "Boist.Input/*.csproj",
            "Boist.Windowing/*.csproj"
          ]
        }
      ],
      "dest": "api",
      "enumSortOrder": "declaringOrder"
    }
  ],
  "build": {
    "content": [
      {
        "files": [
          "**/*.{md,yml}"
        ],
        "exclude": [
          "_site/**"
        ]
      }
    ],
    "resource": [
      {
        "files": [
          "images/**"
        ]
      }
    ],
    "markdownEngineName": "markdig",
    "markdownEngineProperties": {
      "markdigExtensions": [
        "abbreviations",
        "definitionlists",
        "tasklists",
        "footnotes"
      ]
    },
    "output": "_site",
    "template": [
      "default",
      "modern"
    ],
    "globalMetadata": {
      "_appName": "Boist Framework",
      "_appTitle": "Boist Framework",
      "_enableSearch": true,
      "pdf": true
    }
  }
}